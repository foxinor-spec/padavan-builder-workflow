############################################################
### UNIVERSAL CUSTOM PADAVAN CONFIG ###
### MI-4A_100M | MT7628
############################################################

### Target Vendor/Product
CONFIG_VENDOR=XIAOMI
CONFIG_FIRMWARE_PRODUCT_ID="MI-4A_100M"

############################################################
### Linux kernel configuration
############################################################
CONFIG_FIRMWARE_CPU_SLEEP=n

### WiFi drivers
CONFIG_FIRMWARE_WIFI2_DRIVER=4.1
CONFIG_FIRMWARE_WIFI5_DRIVER=3.0

### IPv6
CONFIG_FIRMWARE_ENABLE_IPV6=y

### USB support
CONFIG_FIRMWARE_ENABLE_USB=y
CONFIG_FIRMWARE_INCLUDE_USB_OHCI=y
CONFIG_FIRMWARE_INCLUDE_USB_EHCI=y
CONFIG_FIRMWARE_INCLUDE_USB_HUB=y

### Filesystems
CONFIG_FIRMWARE_ENABLE_FAT=y
CONFIG_FIRMWARE_ENABLE_EXFAT=y
CONFIG_FIRMWARE_ENABLE_FUSE=y
CONFIG_FIRMWARE_ENABLE_SWAP=y
CONFIG_FIRMWARE_INCLUDE_NTFS_3G=y

############################################################
### Languages (RU only)
############################################################
CONFIG_FIRMWARE_INCLUDE_LANG_RU=y
CONFIG_FIRMWARE_INCLUDE_LANG_BR=n
CONFIG_FIRMWARE_INCLUDE_LANG_CN=n
CONFIG_FIRMWARE_INCLUDE_LANG_CZ=n
CONFIG_FIRMWARE_INCLUDE_LANG_DA=n
CONFIG_FIRMWARE_INCLUDE_LANG_DE=n
CONFIG_FIRMWARE_INCLUDE_LANG_ES=n
CONFIG_FIRMWARE_INCLUDE_LANG_FI=n
CONFIG_FIRMWARE_INCLUDE_LANG_FR=n
CONFIG_FIRMWARE_INCLUDE_LANG_NO=n
CONFIG_FIRMWARE_INCLUDE_LANG_PL=n
CONFIG_FIRMWARE_INCLUDE_LANG_SV=n
CONFIG_FIRMWARE_INCLUDE_LANG_UK=n

############################################################
### USB Modem / TTL
############################################################
CONFIG_FIRMWARE_INCLUDE_MODEM=y
CONFIG_FIRMWARE_INCLUDE_MODEM_FILTER=y
CONFIG_FIRMWARE_INCLUDE_USB_NET=y
CONFIG_FIRMWARE_INCLUDE_USB_SERIAL=y
CONFIG_FIRMWARE_INCLUDE_TTL=y

############################################################
### Storage services
############################################################
CONFIG_FIRMWARE_INCLUDE_SMBD=y
CONFIG_FIRMWARE_INCLUDE_SMBD_SYSLOG=y
CONFIG_FIRMWARE_INCLUDE_TESTPARM=y
CONFIG_FIRMWARE_INCLUDE_FTPD=y
CONFIG_FIRMWARE_INCLUDE_FTPD_SSL=y

CONFIG_FIRMWARE_INCLUDE_HDPARM=y
CONFIG_FIRMWARE_INCLUDE_PARTED=y

############################################################
### VPN / Network
############################################################
CONFIG_FIRMWARE_INCLUDE_SERIAL=y
CONFIG_FIRMWARE_INCLUDE_TCPDUMP=y
CONFIG_FIRMWARE_INCLUDE_RPL2TP=y
CONFIG_FIRMWARE_INCLUDE_DDNS_SSL=y
CONFIG_FIRMWARE_INCLUDE_HTTPS=y
CONFIG_FIRMWARE_INCLUDE_SFTP=y
CONFIG_FIRMWARE_INCLUDE_DROPBEAR=y
CONFIG_FIRMWARE_INCLUDE_DROPBEAR_FAST_CODE=y
CONFIG_FIRMWARE_INCLUDE_WIREGUARD=y
CONFIG_FIRMWARE_INCLUDE_AMNEZIAWG=y
CONFIG_FIRMWARE_INCLUDE_OPENSSL_EC=y
CONFIG_FIRMWARE_INCLUDE_OPENSSL_EXE=y
CONFIG_FIRMWARE_INCLUDE_XUPNPD=y
CONFIG_FIRMWARE_INCLUDE_DNSCRYPT=y
CONFIG_FIRMWARE_INCLUDE_STUBBY=y
CONFIG_FIRMWARE_INCLUDE_DOH=y
CONFIG_FIRMWARE_INCLUDE_CURL=y
CONFIG_FIRMWARE_INCLUDE_ZRAM=y
CONFIG_FIRMWARE_INCLUDE_IPERF3=y
CONFIG_FIRMWARE_INCLUDE_NFQWS=y
CONFIG_FIRMWARE_INCLUDE_SHORTCUT_FE=y
CONFIG_FIRMWARE_INCLUDE_IPSET=y

############################################################
### Disabled (save space)
############################################################
CONFIG_FIRMWARE_INCLUDE_TOR=n
CONFIG_FIRMWARE_INCLUDE_MINIDLNA=n
CONFIG_FIRMWARE_INCLUDE_TRANSMISSION=n
CONFIG_FIRMWARE_INCLUDE_ARIA=n
CONFIG_FIRMWARE_INCLUDE_OPENVPN=n
CONFIG_FIRMWARE_INCLUDE_OPENSSH=n
CONFIG_FIRMWARE_INCLUDE_UVC=n
CONFIG_FIRMWARE_INCLUDE_HID=n
CONFIG_FIRMWARE_INCLUDE_AUDIO=n
CONFIG_FIRMWARE_INCLUDE_QOS=n
CONFIG_FIRMWARE_INCLUDE_IMQ=n
CONFIG_FIRMWARE_INCLUDE_IFB=n
CONFIG_FIRMWARE_INCLUDE_NFSD=n
CONFIG_FIRMWARE_INCLUDE_NFSC=n
CONFIG_FIRMWARE_INCLUDE_CIFS=n
CONFIG_FIRMWARE_INCLUDE_LPRD=n
CONFIG_FIRMWARE_INCLUDE_U2EC=n
CONFIG_FIRMWARE_INCLUDE_USBIP=n
CONFIG_FIRMWARE_INCLUDE_SOCAT=n
CONFIG_FIRMWARE_INCLUDE_NDISC6_RDISC6=n
CONFIG_FIRMWARE_INCLUDE_EAP_PEAP=n
CONFIG_FIRMWARE_INCLUDE_QUIC=n
CONFIG_FIRMWARE_INCLUDE_QUIC_NGTCP2=n
CONFIG_FIRMWARE_INCLUDE_OPENSSL_10=n
CONFIG_FIRMWARE_INCLUDE_OPENSSL_11=n
CONFIG_FIRMWARE_INCLUDE_OPENSSL_35=n
CONFIG_FIRMWARE_INCLUDE_WPAD=n
CONFIG_FIRMWARE_INCLUDE_ADB=n
CONFIG_FIRMWARE_INCLUDE_LUA=n
CONFIG_FIRMWARE_INCLUDE_EOIP=n
CONFIG_FIRMWARE_INCLUDE_VLMCSD=n

############################################################
### Optimization
############################################################
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
